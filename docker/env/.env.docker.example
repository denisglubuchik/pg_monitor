PG_MONITOR_APP_NAME=pg-monitor
PG_MONITOR_ENVIRONMENT=dev
PG_MONITOR_HOST=0.0.0.0
PG_MONITOR_PORT=8000
PG_MONITOR_LOG_LEVEL=INFO

PG_MONITOR_COLLECTOR_SCHEDULER_ENABLED=true
PG_MONITOR_RUNTIME_POLL_INTERVAL_SECONDS=60
PG_MONITOR_QUERY_POLL_INTERVAL_SECONDS=900
PG_MONITOR_COLLECTOR_STARTUP_RETRY_ATTEMPTS=5
PG_MONITOR_COLLECTOR_STARTUP_RETRY_BASE_DELAY_SECONDS=1.0
PG_MONITOR_COLLECTOR_STARTUP_RETRY_MAX_DELAY_SECONDS=10.0

PG_MONITOR_PG_DSN=postgresql://postgres:postgres@postgres:5432/monitored_db
PG_MONITOR_STORAGE_DSN=postgresql://postgres:postgres@postgres:5432/pg_monitor_storage
